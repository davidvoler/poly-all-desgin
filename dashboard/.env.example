# Polyglots dashboard — environment template.
# Copy to `assets/.env` and fill in (assets/.env is gitignored).
#
# All values can also be overridden at build time via
# `flutter run --dart-define=API_BASE_URL=...` — the dart-define wins
# when both are set.

# Server base URL the Dio client points at.
API_BASE_URL=http://127.0.0.1:8004

# Audio CDN (parity with poliglots_app — unused by the dashboard today
# but kept here so a single .env shape works for both apps).
AUDIO_BASE_URL=http://127.0.0.1:3002/audio

# Which auth backend the login page should use.
#   local  → email + password against /api/v1/school_users/login (default)
#   auth0  → Auth0 universal login; exchanges ID token at
#            /api/v1/school_users/login_auth0
#   both   → show local form + an "Sign in with Auth0" button
AUTH_PROVIDER=local

# Auth0 SPA application — only read when AUTH_PROVIDER != local.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
# Where Auth0 should send the user back after sign-in. For Flutter web
# this is your dashboard origin; for native it's the custom URL scheme
# you registered in Info.plist / AndroidManifest.
AUTH0_REDIRECT_URI=
