# Polyglots learner app — environment template.
# Copy to `assets/.env` (gitignored) and edit.
#
# `--dart-define=KEY=value` at build time overrides the .env value.

# FastAPI backend.
#   iOS Simulator / macOS / Web : http://127.0.0.1:8004 (default)
#   Android Emulator            : http://10.0.2.2:8004
#   Real phone on Wi-Fi         : http://<your-mac-LAN-ip>:8004
API_BASE_URL=http://127.0.0.1:8004

# Audio CDN served by the nginx audio container.
AUDIO_BASE_URL=http://127.0.0.1:3002/audio

# Which auth backend the login page should use.
#   local  → no Auth0; the login page shows a "Continue as guest" CTA
#            and the server's /auth/get_or_create_user trusts the
#            client-supplied email (only valid when AUTH0_DOMAIN is
#            unset on the server too).
#   auth0  → Auth0 universal login; client sends the ID token to
#            /api/v1/auth/get_or_create_user.
AUTH_PROVIDER=local

# Auth0 SPA application — only read when AUTH_PROVIDER=auth0.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
# For native iOS/Android this is your registered scheme:
#   com.example.poliglots://login-callback
# For web it's the page Auth0 should return to (the same origin as
# the app — Flutter web handles the callback automatically).
AUTH0_REDIRECT_URI=
