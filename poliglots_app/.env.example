# Polyglots learner app — environment template.
# Copy to `assets/.env` (gitignored) and edit.
#
# `--dart-define=KEY=value` at build time overrides the .env value.

# FastAPI backend.
#   iOS Simulator / macOS / Web : http://127.0.0.1:8004 (default)
#   Android Emulator            : http://10.0.2.2:8004
#   Real phone on Wi-Fi         : http://<your-mac-LAN-ip>:8004
API_BASE_URL=http://127.0.0.1:8004

# Audio CDN served by the nginx audio container.
AUDIO_BASE_URL=http://127.0.0.1:3002/audio
